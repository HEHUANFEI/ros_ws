<?xml version="1.0"?>
<launch>
  <arg name="node_name" default="lidar_camera_proj_node"/>
  <arg name="input/lidar" default="/sensing/lidar/concatenated/pointcloud"/>
  <arg name="input/camera" default="/sensing/camera/camera5/image_rect_color"/>
  <arg name="camera_param_path" default="$(find-pkg-share lidar_camera_projector)/config/camera.param.yaml"/>
  <arg name="lidar_camera_calib_param_path" default="$(find-pkg-share lidar_camera_projector)/config/lidar_camera_calib.param.yaml"/>

  <node pkg="lidar_camera_projector" exec="lidar_camera_proj_node" name="$(var node_name)" output="screen">
    <remap from="input/lidar" to="$(var input/lidar)"/>
    <remap from="input/camera" to="$(var input/camera)"/>
    <param from="$(var camera_param_path)"/>
    <param from="$(var lidar_camera_calib_param_path)"/>
  </node>
</launch>
